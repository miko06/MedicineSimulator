DATABASE_URL="postgresql://superuser:superpassword@localhost:54329/medsim?schema=public"
JWT_SECRET="change-me-to-a-random-string-at-least-32-chars"
PORT=8080
CORS_ORIGINS="http://localhost:5173"
ELEVENLABS_API_KEY="sk_your_elevenlabs_api_key_here"
# OpenRouter API key (https://openrouter.ai/keys)
MEDSIM_OPENROUTER_KEY=sk-or-v1-your-key-here
# Primary and fallback models. Free models may be slow; set a paid model for production.
AI_MODEL="nvidia/nemotron-nano-12b-v2-vl:free"
AI_FALLBACK_MODEL="google/gemini-2.0-flash-exp:free"
# Timeout for AI requests (ms). Streaming endpoints fall back to non-streaming on timeout.
AI_TIMEOUT_MS=30000
AI_MAX_TOKENS_CHAT=512
AI_MAX_TOKENS_ANALYSIS=1024
